# LLM API Configuration
# Provider: "anthropic" or "openrouter"
LLM_PROVIDER=openrouter
# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=placeholder
# Only needed if LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_key_here

# Generation Settings
MAX_ITERATIONS=5
# OpenRouter model format - see https://openrouter.ai/models for available models
GENERATION_MODEL=anthropic/claude-opus-4.5
CRITIQUE_MODEL=anthropic/claude-sonnet-4.5
GENERATION_TEMPERATURE=0.7
CRITIQUE_TEMPERATURE=0.3
GENERATION_MAX_TOKENS=4000
CRITIQUE_MAX_TOKENS=2000

# Application Settings
LOG_LEVEL=info
DATA_DIR=./data
CORS_ORIGINS=["http://localhost:8000"]
# Optional: Set to require X-API-Key header on all /api/ routes
# Leave empty for no authentication (local dev mode)
API_AUTH_KEY=

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=false

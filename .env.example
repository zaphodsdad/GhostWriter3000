# LLM API Configuration
LLM_PROVIDER=openrouter  # "anthropic" or "openrouter"
ANTHROPIC_API_KEY=placeholder  # Only needed if LLM_PROVIDER=anthropic
OPENROUTER_API_KEY=your_openrouter_key_here

# Generation Settings
MAX_ITERATIONS=5
GENERATION_MODEL=anthropic/claude-opus-4-20250514  # OpenRouter model format
CRITIQUE_MODEL=anthropic/claude-sonnet-4-20250514  # OpenRouter model format
GENERATION_TEMPERATURE=0.7
CRITIQUE_TEMPERATURE=0.3
GENERATION_MAX_TOKENS=4000
CRITIQUE_MAX_TOKENS=2000

# Application Settings
LOG_LEVEL=info
DATA_DIR=./data
CORS_ORIGINS=["http://localhost:8000"]
API_AUTH_KEY=  # Optional: Set to require X-API-Key header on all /api/ routes

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=false
